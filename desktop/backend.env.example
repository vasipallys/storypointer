# Story Pointer desktop backend settings.
# This file is copied to the user's app-data folder on first desktop launch.
# It is intentionally safe for offline demos; replace these values when using a real LLM/Jira instance.

# --- LLM ---
LLM_PROVIDER=mock
LLM_MODEL=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=3000

# --- Jira (optional) ---
JIRA_INSTANCES=
JIRA_WRITE_ENABLED=false

# Example Jira instance:
# JIRA_INSTANCES=prod
# JIRA_PROD_BASE_URL=https://yourorg.atlassian.net
# JIRA_PROD_AUTH_TYPE=cloud
# JIRA_PROD_EMAIL=
# JIRA_PROD_API_TOKEN=
# JIRA_PROD_STORY_POINTS_FIELD=customfield_10016
# JIRA_PROD_AC_FIELD=

# --- API ---
# Electron file:// renderers send an Origin of "null"; localhost entries support desktop dev mode.
CORS_ORIGINS=null,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
